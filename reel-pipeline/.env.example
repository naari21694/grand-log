# Copy to .env and fill in. Nothing here is committed (.env is gitignored).
# After editing, run `python -m pipeline.doctor` to confirm everything is in place.

# --- paths / tools ---
WORKDIR=./work
FFMPEG=ffmpeg
# Pull cookies from a logged-in browser so Instagram's login wall does not block downloads.
# USE A THROWAWAY INSTAGRAM ACCOUNT. Empty = try without cookies (often fails).
YTDLP_COOKIES_BROWSER=chrome

# --- transcription ---
# faster_whisper = pip-only, cross-platform (best for Windows/dev)
# whisper_cpp    = binary, best on the ARM Oracle box
TRANSCRIBE_BACKEND=faster_whisper
WHISPER_MODEL=large-v3-turbo
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL=

# --- brain: pick ONE provider and bring your own key ---
# gemini    = free tier, text + on-screen vision from one key (recommended to start)
# openai    = any OpenAI-compatible API: OpenAI, OpenRouter, Groq, Together, local Ollama
# anthropic = the official Anthropic API (cheapest reliable model is Haiku)
BRAIN_PROVIDER=gemini
# Vision pass for on-screen quantities: auto | gemini | openai | anthropic | none
BRAIN_VISION=auto

# Gemini (free): get a key at aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible. Pick a row, set the two values, paste your key:
#   OpenAI      OPENAI_BASE_URL=https://api.openai.com/v1       OPENAI_MODEL=gpt-4o-mini
#   OpenRouter  OPENAI_BASE_URL=https://openrouter.ai/api/v1    OPENAI_MODEL=google/gemini-2.5-flash
#   Groq        OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_MODEL=llama-3.3-70b-versatile
#   Ollama      OPENAI_BASE_URL=http://localhost:11434/v1       OPENAI_MODEL=llama3.1   (no key)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic: get a key at console.anthropic.com (the anthropic SDK ships in requirements)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- destination (leave MEALIE_URL empty to force --dry-run behavior) ---
MEALIE_URL=
MEALIE_TOKEN=

# --- Den Den Mushi (Telegram bot): get a token from @BotFather ---
TELEGRAM_BOT_TOKEN=

# --- security ---
# Lock the bot to your own chat. Message the bot once; it replies with your chat id; paste it here.
# Empty, with ALLOW_ALL_CHATS off, means the bot refuses to process any unknown chat.
ALLOWED_CHAT_IDS=
ALLOW_ALL_CHATS=false
# Hosts allowed for download (SSRF guard). Empty uses a safe default list (IG, TikTok, YouTube, ...).
ALLOWED_HOSTS=

# --- dashboard (optional): the tile view, run python -m pipeline.web ---
# Binds localhost by default. Expose it only through a tunnel, and set DASHBOARD_TOKEN if you do.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_TOKEN=
WEBAPP_URL=
