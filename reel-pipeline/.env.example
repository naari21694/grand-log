# Copy to .env and fill in. Nothing here is committed (.env is gitignored).
# After editing, run `python -m pipeline.doctor` to confirm everything is in place.

# --- paths / tools ---
WORKDIR=./work
FFMPEG=ffmpeg
# Instagram's login wall blocks downloads, so use a cookie from a THROWAWAY account.
# Default (works on Windows): export a cookies.txt and drop it at work/cookies.txt - auto-detected.
YTDLP_COOKIES_FILE=
# Override: pull cookies from a logged-in browser profile, e.g. chrome (note: broken on Windows / DPAPI).
YTDLP_COOKIES_BROWSER=

# --- transcription (default just works: GPU if present, else CPU) ---
TRANSCRIBE_BACKEND=faster_whisper   # faster_whisper (local) | groq (free cloud) | whisper_cpp (ARM)
WHISPER_DEVICE=auto                 # auto-detects an NVIDIA GPU; force with cpu | cuda
WHISPER_COMPUTE=                    # blank: int8_float16 on GPU, int8 on CPU
WHISPER_MODEL=large-v3-turbo
# Override: free, fast cloud Whisper off your machine. Set TRANSCRIBE_BACKEND=groq + a key (console.groq.com)
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# Override: whisper.cpp binary for ARM/Pi
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL=

# --- capture mode ---
# auto    = read the caption first; download the video and run Whisper only if the caption is thin
# caption = never download the video (fast, no Whisper; misses audio-only / on-screen-only reels)
# full    = always download and transcribe
CAPTURE_MODE=auto
# Keep the downloaded video, frames, and thumbnail as a local archive; false = delete after extraction.
KEEP_MEDIA=true

# --- backfill (offline ingest of your Instagram saved export) ---
# The Gemini free tier (about 20 requests a day) is too small for a full backlog. For the backfill,
# point BRAIN_PROVIDER (below) at Groq (free, fast) or a local Ollama (free, unlimited), or add
# billing to a Gemini key (about a dollar for the whole backlog), and keep Gemini for live shares.
# BACKFILL_SLEEP pauses this many seconds after each AI call to stay under the provider's rate limit.
# 0 = no pause. On the Gemini free tier, 4 is a safe start; a higher-limit provider can use 0 to 2.
BACKFILL_SLEEP=4

# --- brain: pick ONE provider and bring your own key ---
# gemini    = free tier, text + on-screen vision from one key (recommended to start)
# openai    = any OpenAI-compatible API: OpenAI, OpenRouter, Groq, Together, local Ollama
# anthropic = the official Anthropic API (cheapest reliable model is Haiku)
BRAIN_PROVIDER=gemini
# Vision pass for on-screen quantities: auto | gemini | openai | anthropic | none
BRAIN_VISION=auto

# Gemini (free): get a key at aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible. Pick a row, set the two values, paste your key:
#   OpenAI      OPENAI_BASE_URL=https://api.openai.com/v1       OPENAI_MODEL=gpt-4o-mini
#   OpenRouter  OPENAI_BASE_URL=https://openrouter.ai/api/v1    OPENAI_MODEL=google/gemini-2.5-flash
#   Groq        OPENAI_BASE_URL=https://api.groq.com/openai/v1  OPENAI_MODEL=llama-3.3-70b-versatile
#   Ollama      OPENAI_BASE_URL=http://localhost:11434/v1       OPENAI_MODEL=llama3.1   (no key)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic: get a key at console.anthropic.com (the anthropic SDK ships in requirements)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- destination (leave MEALIE_URL empty to force --dry-run behavior) ---
MEALIE_URL=
MEALIE_TOKEN=

# --- Den Den Mushi (Telegram bot): get a token from @BotFather ---
TELEGRAM_BOT_TOKEN=

# --- worker ---
# A transient Instagram/network blip retries with backoff instead of dropping the reel;
# a job is dead-lettered after this many tries.
WORKER_MAX_ATTEMPTS=3

# --- security ---
# Lock the bot to your own chat. Message the bot once; it replies with your chat id; paste it here.
# Empty, with ALLOW_ALL_CHATS off, means the bot refuses to process any unknown chat.
ALLOWED_CHAT_IDS=
ALLOW_ALL_CHATS=false
# Hosts allowed for download (SSRF guard). Empty uses a safe default list (IG, TikTok, YouTube, ...).
ALLOWED_HOSTS=

# --- dashboard (optional): the tile view, run python -m pipeline.web ---
# Binds localhost by default. Expose it only through a tunnel, and set DASHBOARD_TOKEN if you do.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_TOKEN=
WEBAPP_URL=
