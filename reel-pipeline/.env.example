# Copy to .env and fill in. Nothing here is committed.

# --- paths / tools ---
WORKDIR=./work
FFMPEG=ffmpeg
# Pull cookies from a logged-in browser so IG's login wall doesn't block you.
# USE A THROWAWAY INSTAGRAM ACCOUNT. Empty = try without cookies (often fails).
YTDLP_COOKIES_BROWSER=chrome

# --- transcription ---
# faster_whisper = pip-only, cross-platform (best for Windows/dev)
# whisper_cpp    = binary, best on the ARM Oracle box
TRANSCRIBE_BACKEND=faster_whisper
WHISPER_MODEL=large-v3-turbo
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL=

# --- brain ---
# text: claude_p (Claude Code CLI + Max credit) | gemini
BRAIN_TEXT=claude_p
CLAUDE_BIN=claude
CLAUDE_MODEL=
# vision: gemini (free tier) | none
BRAIN_VISION=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- destination (leave MEALIE_URL empty to force --dry-run behavior) ---
MEALIE_URL=
MEALIE_TOKEN=

# --- Den Den Mushi (Telegram bot): get a token from @BotFather ---
TELEGRAM_BOT_TOKEN=

# --- dashboard (optional): the tile view, run python -m pipeline.web ---
DASHBOARD_PORT=8080
WEBAPP_URL=
